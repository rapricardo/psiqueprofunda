---
import { getImage } from 'astro:assets';
import bgImage from '@/assets/images/deia-grupo-celebracao.png';

const optimizedBg = await getImage({ src: bgImage, width: 1920 });

const painItems = [
  'Vive em função das expectativas dos outros.',
  'Toma decisões para manter equilíbrio, não para viver a sua verdade.',
  'Sente cansaço emocional mesmo quando tudo parece "bem".',
  'Perdeu contato com o que realmente deseja.',
];
---

<section
  class="section-spacing relative overflow-hidden"
  style={`background-image: url('${optimizedBg.src}'); background-size: cover; background-position: center;`}
>
  <div class="absolute inset-0 bg-bg-secondary/[0.92]"></div>
  <div class="container mx-auto px-6 text-center relative z-10">
    <div data-aos="fade-up" class="max-w-[600px] mx-auto">
      <h2 class="text-4xl md:text-5xl mb-14">Talvez você reconheça isso.</h2>
      <div class="space-y-6 text-left max-w-[520px] mx-auto">
        {painItems.map((item, i) => (
          <div data-aos="fade-up" data-aos-delay={i * 80} class="flex items-baseline gap-4 border-b border-detail/10 pb-6">
            <div class="w-2 h-2 rounded-full bg-accent shrink-0 relative top-[-1px]" />
            <p class="text-base md:text-lg text-text-body leading-relaxed">{item}</p>
          </div>
        ))}
      </div>
      <p class="text-2xl md:text-3xl serif-italic text-detail mt-14" data-aos="fade-up" data-aos-delay="350">
        Isso não é fraqueza. É desconexão.
      </p>
    </div>
  </div>
</section>
