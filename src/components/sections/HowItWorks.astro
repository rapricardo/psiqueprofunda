---
const items = [
  {
    text: '8 encontros ao vivo',
    icon: `<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>`,
  },
  {
    text: 'Exercícios estruturados entre encontros',
    icon: `<circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/>`,
  },
  {
    text: 'Material complementar exclusivo',
    icon: `<rect width="7" height="7" x="14" y="3" rx="1"/><path d="M10 21V8a1 1 0 0 0-1-1H4a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-5a1 1 0 0 0-1-1H3"/>`,
  },
  {
    text: 'Grupo fechado e intimista',
    icon: `<path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"/>`,
  },
  {
    text: 'Acesso por período determinado',
    icon: `<path d="M21.801 10A10 10 0 1 1 17 3.335"/><path d="m9 11 3 3L22 4"/>`,
  },
];
---

<section class="section-spacing bg-bg-primary">
  <div class="container mx-auto px-6">
    <h2 data-aos="fade-up" class="text-4xl md:text-5xl text-center mb-20">Como acontece.</h2>
    <div class="max-w-2xl mx-auto space-y-12">
      {items.map((item, i) => (
        <div data-aos="fade-up" data-aos-delay={i * 100} class="flex items-center gap-8 group">
          <div class="w-12 h-12 flex items-center justify-center border border-detail/20 rounded-full group-hover:border-accent transition-colors shrink-0">
            <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
              <Fragment set:html={item.icon} />
            </svg>
          </div>
          <p class="text-xl text-text-body">{item.text}</p>
        </div>
      ))}
    </div>
  </div>
</section>
