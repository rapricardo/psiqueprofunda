    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl mx-auto">
      <div data-aos="fade-up" class="p-10 md:p-12 bg-white/60 border border-detail/5 rounded-xl">
        <h3 class="text-sm uppercase tracking-[0.2em] text-text-muted mb-8 font-sans">Reatividade</h3>
