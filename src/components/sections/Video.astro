---
import { YouTube } from '@astro-community/astro-embed-youtube';
---

<section class="section-spacing bg-bg-video">
  <div class="container mx-auto px-6">
    <div data-aos="fade-up" class="max-w-3xl mx-auto text-center">
      <h2 class="text-4xl md:text-5xl text-white/95 mb-4">Assista antes de decidir.</h2>
      <p class="text-white/60 text-lg mb-10">Uma conversa honesta sobre o que é — e o que não é — este programa.</p>
    </div>
    <div data-aos="fade-up" data-aos-delay="150" class="max-w-4xl mx-auto">
      <div class="rounded-2xl overflow-hidden shadow-2xl">
        <YouTube id="aTCWZ6mvdHw" title="Despertar — O Retorno Consciente" />
      </div>
    </div>
  </div>
</section>
