---
const pilares = [
  { title: 'Consciência', desc: 'Identificar os mecanismos internos que sustentaram sua estrutura até hoje, perceber suas limitações e caminhos para superá-las.' },
  { title: 'Desconstrução', desc: 'Questionar narrativas, identidades e exigências internas sem culpa, abrindo espaço para uma nova organização interna.' },
  { title: 'Integração', desc: 'Aprender a sustentar paradoxos - força e vulnerabilidade, controle e entrega, clareza e incerteza - sem se fragmentar.' },
  { title: 'Autoria', desc: 'Escolher a partir do que é verdadeiro em você, com segurança, presença e clareza.' },
];
---

<section class="section-spacing bg-bg-secondary">
  <div class="container mx-auto px-6">
    <div class="text-center mb-16">
      <h2 data-aos="fade-up" class="text-4xl md:text-5xl mb-4">Estrutura — Método em 4 pilares.</h2>
      <p data-aos="fade-up" data-aos-delay="100" class="text-text-muted text-lg">Não é imersão emocional desorganizada. É processo consciente.</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl mx-auto">
      {pilares.map((pilar, i) => (
        <div
          data-aos="fade-up"
          data-aos-delay={i * 100}
          class="bg-white p-8 md:p-10 rounded-xl relative overflow-hidden group hover:bg-accent/[0.03] transition-colors"
        >
          <span class="absolute -top-2 -right-2 text-8xl font-serif text-accent/[0.07] group-hover:text-accent/15 transition-colors select-none">
            0{i + 1}
          </span>
          <h3 class="text-xl font-bold mb-3 relative z-10">{pilar.title}</h3>
          <p class="text-text-body leading-relaxed relative z-10">{pilar.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
