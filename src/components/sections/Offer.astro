---
const hotmartUrl = 'https://pay.hotmart.com/B95434104W?off=f5gi2zyq';
---

<section class="section-spacing bg-bg-secondary border-t border-detail/10">
  <div class="container mx-auto px-6 text-center">
    <div data-aos="fade-up" class="max-w-3xl mx-auto">
      <h2 class="text-5xl md:text-6xl mb-8">Despertar — O Retorno para Si</h2>
      <p class="text-lg text-text-body mb-12">
        50+ aulas gravadas · Método estruturado · Apostila completa · Acesso por 2 anos
      </p>
      <div class="mb-12">
        <span class="text-text-muted text-sm block mb-2">Investimento</span>
        <span class="text-4xl md:text-5xl font-serif text-text-primary">12x de R$ 103,11</span>
        <p class="text-text-body text-lg mt-3">ou <strong class="text-text-primary">R$ 997,00</strong> à vista</p>
        <p class="text-text-muted text-sm mt-4">Vagas limitadas para garantir profundidade do processo.</p>
      </div>
      <a href={hotmartUrl} target="_blank" rel="noopener noreferrer" class="btn-primary group text-lg px-12 py-6">
        Quero começar meu processo
        <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7" /></svg>
      </a>
    </div>
  </div>
</section>
